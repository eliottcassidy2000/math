  n= 7: avg 3-cyc=     8.8, avg 5-cyc=     0.5, ratio= 0.053, f₅=0.0505, (3+2f₅)²=9.62 ≥n ✓
  n= 8: avg 3-cyc=    14.1, avg 5-cyc=     1.2, ratio= 0.088, f₅=0.0809, (3+2f₅)²=10.00 ≥n ✓
  n= 9: avg 3-cyc=    21.1, avg 5-cyc=     3.2, ratio= 0.150, f₅=0.1306, (3+2f₅)²=10.63 ≥n ✓
  n=10: avg 3-cyc=    30.1, avg 5-cyc=     6.0, ratio= 0.200, f₅=0.1666, (3+2f₅)²=11.11 ≥n ✓
  n=11: avg 3-cyc=    41.4, avg 5-cyc=    11.3, ratio= 0.272, f₅=0.2140, (3+2f₅)²=11.75 ≥n ✓
  n=12: avg 3-cyc=    54.4, avg 5-cyc=    18.2, ratio= 0.334, f₅=0.2501, (3+2f₅)²=12.25 ≥n ✓
