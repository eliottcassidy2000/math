   3       11         45   3√5=  6.708     3.854102    -2.854102               -1 + 3φ
   5       31        125   5√5= 11.180     6.090170    -5.090170               -2 + 5φ
   7       61        245   7√5= 15.652     8.326238    -7.326238               -3 + 7φ
   9      101        405   9√5= 20.125    10.562306    -9.562306               -4 + 9φ
  11      151        605  11√5= 24.597    12.798374   -11.798374              -5 + 11φ
  13      211        845  13√5= 29.069    15.034442   -14.034442              -6 + 13φ
  15      281       1125  15√5= 33.541    17.270510   -16.270510              -7 + 15φ
  17      361       1445  17√5= 38.013    19.506578   -18.506578              -8 + 17φ
  19      451       1805  19√5= 42.485    21.742646   -20.742646              -9 + 19φ
  21      551       2205  21√5= 46.957    23.978714   -22.978714             -10 + 21φ
  23      661       2645  23√5= 51.430    26.214782   -25.214782             -11 + 23φ
  25      781       3125  25√5= 55.902    28.450850   -27.450850             -12 + 25φ
  27      911       3645  27√5= 60.374    30.686918   -29.686918             -13 + 27φ
  29     1051       4205  29√5= 64.846    32.922986   -31.922986             -14 + 29φ
  31     1201       4805  31√5= 69.318    35.159054   -34.159054             -15 + 31φ
  33     1361       5445  33√5= 73.790    37.395122   -36.395122             -16 + 33φ
  35     1531       6125  35√5= 78.262    39.631190   -38.631190             -17 + 35φ
