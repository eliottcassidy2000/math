    corr(H, trop_det) = 0.8903
    corr(H, n_max_perms) = -0.3595

  INTERPRETATION:
    Tropical det = n when a Hamiltonian cycle exists (all arcs forward)
    trop_det < n when best permutation has backward arcs
    # max perms counts the number of optimal Hamiltonian cycles

  TROPICAL EIGENVALUES:
    lambda_trop = max cycle mean weight = max_C (|C|^{-1} * sum_C w(i,j))

