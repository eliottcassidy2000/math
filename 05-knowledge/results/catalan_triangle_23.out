  n=5, m=n-3=2: conv3=     9, FC(3,2)=     3, C(2m+2,m+1)/(m+2)=     5
  n=6, m=n-3=3: conv3=    28, FC(3,3)=    12, C(2m+2,m+1)/(m+2)=    14
  n=7, m=n-3=4: conv3=    90, FC(3,4)=    55, C(2m+2,m+1)/(m+2)=    42
  n=8, m=n-3=5: conv3=   297, FC(3,5)=   273, C(2m+2,m+1)/(m+2)=   132
  n=9, m=n-3=6: conv3=  1001, FC(3,6)=  1428, C(2m+2,m+1)/(m+2)=   429
