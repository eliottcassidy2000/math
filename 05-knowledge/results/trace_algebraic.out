======================================================================
ALGEBRAIC STRUCTURE OF TRACE SUMS
======================================================================

--- Section 1: S_P(k) as polynomial in p ---
S_P(k) = m * [(i*sqrt(p)-1)^k - (i*sqrt(p)+1)^k] / 2^k
       = -m / 2^{k-1} * sum_{l=0}^{(k-1)/2} C(k,2l)*(-p)^l

  k=3: P(p) = 1 + -3*p^1
    p=7: P(p)=-20, S_P = 15, direct = 15, match = True
    p=11: P(p)=-32, S_P = 40, direct = 40, match = True
    p=19: P(p)=-56, S_P = 126, direct = 126, match = True

  k=5: P(p) = 1 + -10*p^1 + 5*p^2
