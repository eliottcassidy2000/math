    p=11: P(p)=496, S_P = -155, direct = -155, match = True
    p=19: P(p)=1616, S_P = -909, direct = -909, match = True

  k=7: P(p) = 1 + -21*p^1 + 35*p^2 + -7*p^3
    p=7: P(p)=-832, S_P = 39, direct = 39, match = True
    p=11: P(p)=-5312, S_P = 415, direct = 415, match = True
    p=19: P(p)=-35776, S_P = 5031, direct = 5031, match = True

  k=9: P(p) = 1 + -36*p^1 + 126*p^2 + -84*p^3 + 9*p^4
