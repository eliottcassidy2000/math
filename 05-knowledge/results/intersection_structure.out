    dc3=10: dp33 ∈ [2, 4, 5, 6, 7, 8] (6 values)
    dc3=11: dp33 ∈ [4, 5, 6, 7, 8, 9, 10] (7 values)
    dc3=12: dp33 ∈ [5, 6, 7, 8, 10, 11, 12] (7 values)
    dc3=13: dp33 ∈ [8, 9, 10, 12] (4 values)

