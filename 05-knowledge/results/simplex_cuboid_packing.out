    complement/simplex = 4.0625 = (3/2)^4 - 1 = 4.0625

  n=5: complement = (x+2)^5 - (x+1)^5
    = 5*(x+1)^4 + 10*(x+1)^3 + 10*(x+1)^2 + 5*(x+1)^1 + 1*(x+1)^0
