    complement/simplex = 2.3750 = (3/2)^3 - 1 = 2.3750

  n=4: complement = (x+2)^4 - (x+1)^4
    = 4*(x+1)^3 + 6*(x+1)^2 + 4*(x+1)^1 + 1*(x+1)^0
