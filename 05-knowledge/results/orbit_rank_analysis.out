  R_2=1, R_5=1  ratio=1.0000
  R_3=1, R_4=2  ratio=0.5000
  R_4=2, R_3=1  ratio=2.0000
  R_5=1, R_2=1  ratio=1.0000
  R_6=1, R_1=0  (r2=0)
  R_7=0, R_0=0  (r2=0)

