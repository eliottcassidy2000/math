  d+=2, pos=(start=5, mid=4, end=5): 120 pairs
  d+=3, pos=(start=4, mid=3, end=1): 480 pairs
  d+=3, pos=(start=5, mid=3, end=2): 480 pairs
  d+=3, pos=(start=3, mid=3, end=0): 160 pairs
  d+=3, pos=(start=6, mid=3, end=3): 160 pairs

--- Ω₂ basis analysis for v-elements ---
(d2_T, d2_sub, rk_incl, d_rel_incl, rk_sub_nonv, d_rel_nonv) → count:
  (9, 3, 3, 6, 4, 5) → 1800  ✗ MISMATCH
  (9, 4, 4, 5, 4, 5) → 1200  ✓
  (10, 3, 3, 7, 5, 5) → 600  ✗ MISMATCH
  (10, 4, 4, 6, 4, 6) → 480  ✓
  (8, 3, 3, 5, 4, 4) → 120  ✗ MISMATCH
  (9, 3, 3, 6, 5, 4) → 120  ✗ MISMATCH
  (9, 3, 3, 6, 3, 6) → 80  ✓
  (8, 3, 3, 5, 3, 5) → 80  ✓

--- Part 3: Structure of relative H₂ generator ---
For first 5 cases with h₂_rel=1:

Tournament bits=0, v=1 (d+=1), h₂_rel=1:
  Adjacency: ['00000', '10000', '11000', '11100', '11110']
  -0.500 * (2, 1, 0) [TT, v@mid]
  -0.167 * (3, 1, 0) [TT, v@mid]
  +0.167 * (4, 3, 1) [TT, v@end]
  +0.500 * (4, 2, 1) [TT, v@end]
  +0.667 * (4, 1, 0) [TT, v@mid]
  ∂₂ norm = 1.000000
    ∂: +0.500 * (2, 0) [non-v]
    ∂: +0.167 * (3, 0) [non-v]
    ∂: +0.167 * (4, 3) [non-v]
    ∂: +0.500 * (4, 2) [non-v]
    ∂: -0.667 * (4, 0) [non-v]

Tournament bits=0, v=2 (d+=2), h₂_rel=1:
  Adjacency: ['00000', '10000', '11000', '11100', '11110']
  +0.500 * (2, 1, 0) [TT, v@start]
  -0.604 * (3, 2, 1) [TT, v@mid]
  +0.604 * (3, 2, 0) [TT, v@mid]
  +0.104 * (4, 2, 1) [TT, v@mid]
  -0.104 * (4, 2, 0) [TT, v@mid]
  ∂₂ norm = 1.000000
    ∂: +0.500 * (1, 0) [non-v]
    ∂: +0.604 * (3, 1) [non-v]
    ∂: -0.604 * (3, 0) [non-v]
    ∂: -0.104 * (4, 1) [non-v]
    ∂: +0.104 * (4, 0) [non-v]

Tournament bits=0, v=3 (d+=3), h₂_rel=1:
  Adjacency: ['00000', '10000', '11000', '11100', '11110']
  -0.354 * (3, 2, 1) [TT, v@start]
  +0.354 * (3, 2, 0) [TT, v@start]
  -0.707 * (3, 1, 0) [TT, v@start]
  +0.354 * (4, 3, 1) [TT, v@mid]
  -0.354 * (4, 3, 0) [TT, v@mid]
  ∂₂ norm = 1.000000
    ∂: -0.707 * (1, 0) [non-v]
    ∂: -0.354 * (2, 1) [non-v]
    ∂: +0.354 * (2, 0) [non-v]
    ∂: -0.354 * (4, 1) [non-v]
    ∂: +0.354 * (4, 0) [non-v]

Tournament bits=1, v=0 (d+=1), h₂_rel=1:
  Adjacency: ['01000', '00000', '11000', '11100', '11110']
  +0.028 * (3, 2, 0) [TT, v@end]
  -0.567 * (3, 0, 1) [TT, v@mid]
  +0.595 * (4, 3, 0) [TT, v@end]
  -0.028 * (4, 2, 0) [TT, v@end]
  +0.567 * (4, 0, 1) [TT, v@mid]
  ∂₂ norm = 1.000000
    ∂: +0.028 * (3, 2) [non-v]
    ∂: +0.567 * (3, 1) [non-v]
    ∂: +0.595 * (4, 3) [non-v]
    ∂: -0.028 * (4, 2) [non-v]
    ∂: -0.567 * (4, 1) [non-v]

Tournament bits=1, v=2 (d+=2), h₂_rel=1:
  Adjacency: ['01000', '00000', '11000', '11100', '11110']
  +0.500 * (2, 0, 1) [TT, v@start]
  +0.604 * (3, 2, 1) [TT, v@mid]
  -0.604 * (3, 2, 0) [TT, v@mid]
  -0.104 * (4, 2, 1) [TT, v@mid]
  +0.104 * (4, 2, 0) [TT, v@mid]
  ∂₂ norm = 1.000000
    ∂: +0.500 * (0, 1) [non-v]
    ∂: -0.604 * (3, 1) [non-v]
    ∂: +0.604 * (3, 0) [non-v]
    ∂: +0.104 * (4, 1) [non-v]
    ∂: -0.104 * (4, 0) [non-v]

Done.
