=== OMEGA_ORB_3 PATTERN ===

m = [3, 5, 9]
Ω_3^orb = [3, 14, 60]
  m=3: (m-1)(2m-3)/2 = 3 ✓
  m=5: (m-1)(2m-3)/2 = 14 ✓
  m=9: (m-1)(2m-3)/2 = 60 ✓

Ω_3^orb = (m-1)(2m-3)/2
Ω_3 = m*(m-1)(2m-3)/2
Compare: |A_3| = m*(m-1)(2m+1)/2
Junk_3 = |A_3| - Ω_3 = m*(m-1)*(2m+1-2m+3)/2 = m*(m-1)*4/2 = 2m(m-1)
  m=3: junk_orb = 4, 2(m-1) = 4 ✓
  m=5: junk_orb = 8, 2(m-1) = 8 ✓
  m=9: junk_orb = 16, 2(m-1) = 16 ✓

