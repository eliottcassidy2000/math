--- PART 4: DISC VERIFICATION VIA SIN PRODUCT ---
disc = prod_{i<j} (Q_i - Q_j)^2
     = prod_{i<j} (sin^2(pi*sigma(i)/p)/sin^2(pi*i/p) - sin^2(pi*sigma(j)/p)/sin^2(pi*j/p))^2

  p=23, m=11: disc = p^10 * 1
    m-1 = 10
    disc = p^(m-1)? YES

  p=29, m=14: disc = p^13 * 1
    m-1 = 13
    disc = p^(m-1)? YES

  p=31, m=15: disc = p^14 * 1
    m-1 = 14
    disc = p^(m-1)? YES
