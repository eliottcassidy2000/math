======================================================================
DEEPEST AMBIGUITY PAIR: n=7 Pfaffian analysis
======================================================================

  H=109, c7=8:
    H = 109, c7 = 8
    w = [-7, 1, 3, -7, -1, -3, 1]
    Pf_sum = sum(w) = -13
    Pf_sum^2 = 169
    det(J+S) = 169
    det(I+2A) = 169
    Match: Pf_sum^2 = det(J+S) = det(I+2A)? True
    Deletion Pfaffians:
      Pf(S\0) = -7 (det = 49 = -7^2 = 49)
      Pf(S\1) = -1 (det = 1 = -1^2 = 1)
      Pf(S\2) = +3 (det = 9 = 3^2 = 9)
      Pf(S\3) = +7 (det = 49 = 7^2 = 49)
      Pf(S\4) = -1 (det = 1 = -1^2 = 1)
      Pf(S\5) = +3 (det = 9 = 3^2 = 9)
      Pf(S\6) = +1 (det = 1 = 1^2 = 1)

  H=111, c7=9:
    H = 111, c7 = 9
    w = [-9, 1, -3, 3, -9, -1, -1]
    Pf_sum = sum(w) = -19
    Pf_sum^2 = 361
    det(J+S) = 361
    det(I+2A) = 361
