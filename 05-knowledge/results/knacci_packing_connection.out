         (1)      1     1     1     1.0000     1.0000
       (1,1)      2     3     4     1.5000     1.3333
     (1,2,0)      3     5     7     1.6667     1.4000
     (1,4,0)      5     9    13     1.8000     1.4444
     (1,5,0)      6    11    16     1.8333     1.4545
