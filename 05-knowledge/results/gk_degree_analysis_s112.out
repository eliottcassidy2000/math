==============================================================================
PART 1: NAIVE FORMULA AS POLYNOMIALS
==============================================================================

k=1: g_k^naive(m) = x
       degree = 1

k=2: g_k^naive(m) = x**2
       degree = 2

k=3: g_k^naive(m) = 2*x**3/3 + x/3
       degree = 3

k=4: g_k^naive(m) = x**4/3 + 2*x**2/3
       degree = 4

k=5: g_k^naive(m) = 2*x**5/15 + 2*x**3/3 + x/5
       degree = 5

k=6: g_k^naive(m) = 2*x**6/45 + 4*x**4/9 + 23*x**2/45
       degree = 6

k=7: g_k^naive(m) = 4*x**7/315 + 2*x**5/9 + 28*x**3/45 + x/7
       degree = 7

k=8: g_k^naive(m) = x**8/315 + 4*x**6/45 + 22*x**4/45 + 44*x**2/105
       degree = 8

k=9: g_k^naive(m) = 2*x**9/2835 + 4*x**7/135 + 38*x**5/135 + 1636*x**3/2835 + x/9
       degree = 9


