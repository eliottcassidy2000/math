C_0 = 1, C_1 = 1, C_2 = 2 = KEY1, C_3 = 5 = KEY_SUM
C_4 = 14 = 2*7 = KEY1*H_forb_1
C_5 = 42 = 2*3*7 = KEY1*KEY2*H_forb_1
C_6 = 132 = 4*3*11
C_7 = 429 = 3*11*13

