--- Bottom alternating sum (determines R_m^{(0)}) ---
  R_1 = Omega_0 - R_0 = 1 - 0 = 1
  R_2 = Omega_1 - R_1 = 3 - 1 = 2
  R_3 = Omega_2 - R_2 = 6 - 2 = 4
  => R_m = R_3 = 4

--- Top alternating sum (determines R_{m+2}^{(0)}) ---
  R_6 = Omega_6 - R_7 = 3 - 0 = 3
  R_5 = Omega_5 - R_6 = 6 - 3 = 3
  => R_{m+2} = R_5 = 3

  Budget at d=m: Omega_m - R_m = 9 - 4 = 5
  This equals R_{m+1} + β_m
  From top: R_{m+1} + β_{m+1} = Omega_{m+1} - R_{m+2} = 9 - 3 = 6
  Since β_m = β_{m+1}: both sides = 5

--- R_m as alternating sum ---
  R_m = Σ (-1)^{m-1-j} Omega_j for j=0..2
      = (+1)*1 + (-1)*3 + (+1)*6
      = 4
  R_{m+2} = Σ (-1)^{j-m-2} Omega_j for j=5..6
      = (+1)*6 + (-1)*3
      = 3

  β_m = Omega_m - R_m - R_{m+1}
      = 9 - 4 - R_{m+1}
  We know β_m = m(m-3)/2 = 0
  So R_{m+1} = 5


=== P_11 (m=5) ===
  R_m = R_5 = Σ (-1)^{4-j} Omega_j = 151
  R_{m+2} = R_7 = Σ (-1)^{j-7} Omega_j = 390
  Budget = Omega_5 - R_5 = 309
  β_m = m(m-3)/2 = 5
  R_6 = Budget - β_m = 304

