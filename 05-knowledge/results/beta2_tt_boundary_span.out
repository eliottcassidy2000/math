======================================================================
WHEN #TT >= dim_Z1, IS rk = dim_Z1?
======================================================================
n=5: #TT = C(n,3) - c_3 verified for all tournaments

======================================================================
#TT vs dim_Z1
======================================================================

n=5: dim_Z1=6, C(n,3)=10
  #TT = C(n,3) - c_3 >= dim_Z1 iff c_3 <= 4
  Max c_3 = C(n,3)/4 = 2.5 (regular tournament)

n=6: dim_Z1=10, C(n,3)=20
  #TT = C(n,3) - c_3 >= dim_Z1 iff c_3 <= 10
  Max c_3 = C(n,3)/4 = 5.0 (regular tournament)

n=7: dim_Z1=15, C(n,3)=35
  #TT = C(n,3) - c_3 >= dim_Z1 iff c_3 <= 20
  Max c_3 = C(n,3)/4 = 8.8 (regular tournament)

