  n=2: Vol(simplex)/Vol(cube) = 1/2 = 0.500000, complement fraction = 0.500000
  n=3: Vol(simplex)/Vol(cube) = 1/6 = 0.166667, complement fraction = 0.833333
  n=4: Vol(simplex)/Vol(cube) = 1/24 = 0.041667, complement fraction = 0.958333
  n=5: Vol(simplex)/Vol(cube) = 1/120 = 0.008333, complement fraction = 0.991667
  n=6: Vol(simplex)/Vol(cube) = 1/720 = 0.001389, complement fraction = 0.998611
  n=7: Vol(simplex)/Vol(cube) = 1/5040 = 0.000198, complement fraction = 0.999802
  n=8: Vol(simplex)/Vol(cube) = 1/40320 = 0.000025, complement fraction = 0.999975

