======================================================================
PART 3: WRITHE vs H -- DEEP CORRELATION ANALYSIS
  Writhe = #{ascending arcs} - #{descending arcs}
  Analogy: knot writhe measures 'twistedness'
======================================================================

--- n = 4 ---
  Correlation(H, writhe) = 0.000000
  Correlation(H, |writhe|) = -0.274721
  Correlation(H, writhe^2) = -0.298142
  Linear fit H ~ 3.4000 + -0.066667 * writhe^2
  R^2 = 0.088889
  H at writhe=0: mean=3.40, range=[1,5]
  H at |writhe|=6: always H={1}

--- n = 5 ---
  Correlation(H, writhe) = 0.000000
  Correlation(H, |writhe|) = -0.249342
  Correlation(H, writhe^2) = -0.264906
  Linear fit H ~ 8.3333 + -0.083333 * writhe^2
  R^2 = 0.070175
  H at writhe=0: mean=8.38, range=[1,15]
  H at |writhe|=10: always H={1}

--- n = 6 ---
  Correlation(H, writhe) = -0.003989
  Correlation(H, |writhe|) = -0.199806
  Correlation(H, writhe^2) = -0.214839
  Linear fit H ~ 23.9653 + -0.115870 * writhe^2
  R^2 = 0.046156
  H at |writhe|=15: always H={1}

