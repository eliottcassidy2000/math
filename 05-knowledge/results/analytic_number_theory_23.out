======================================================================
PART 1: θ-SERIES Θ_n(q) = Σ_T q^{H(T)}
======================================================================

n=3: Θ_3(q) = 6·q^1 + 2·q^3
  Θ_3(-1) = -8
  Θ_3(i) = 4j
  Θ_3(1) = 8 = 2^3
  Θ'_3(1) = 12 = 8 · 1.5000

n=4: Θ_4(q) = 24·q^1 + 16·q^3 + 24·q^5
  Θ_4(-1) = -64
  Θ_4(i) = 32j
  Θ_4(1) = 64 = 2^6
  Θ'_4(1) = 192 = 64 · 3.0000

n=5: Θ_5(q) = 120·q^1 + 120·q^3 + 240·q^5 + 240·q^9 + 120·q^11 + 120·q^13 + 64·q^15
  Θ_5(-1) = -1024
  Θ_5(i) = 416j
  Θ_5(1) = 1024 = 2^10
  Θ'_5(1) = 7680 = 1024 · 7.5000

n=6: Θ_6(q) = 720·q^1 + 960·q^3 + 2160·q^5 + 2960·q^9 + 1440·q^11 + 1440·q^13 + 2208·q^15 + 1440·q^17 + 1440·q^19 + 2880·q^23 + 1440·q^25 + 480·q^27 + 2880·q^29 + 1440·q^31 + 2640·q^33 + 3600·q^37 + 720·q^41 + 1440·q^43 + 480·q^45
  Θ_6(-1) = -32768
  Θ_6(i) = 8192j
  Θ_6(1) = 32768 = 2^15
  Θ'_6(1) = 737280 = 32768 · 22.5000

