======================================================================
  bits=0: scores=(np.int64(0), np.int64(1), np.int64(2)), H=1, betti=[np.int64(1), np.int64(0), np.int64(0)], omega=[3, 3, 1]
  bits=1: scores=(np.int64(0), np.int64(1), np.int64(2)), H=1, betti=[np.int64(1), np.int64(0), np.int64(0)], omega=[3, 3, 1]
  bits=2: scores=(np.int64(1), np.int64(1), np.int64(1)), H=3, betti=[np.int64(1), np.int64(1), 0], omega=[3, 3, 0]
  bits=3: scores=(np.int64(0), np.int64(1), np.int64(2)), H=1, betti=[np.int64(1), np.int64(0), np.int64(0)], omega=[3, 3, 1]
  bits=4: scores=(np.int64(0), np.int64(1), np.int64(2)), H=1, betti=[np.int64(1), np.int64(0), np.int64(0)], omega=[3, 3, 1]
