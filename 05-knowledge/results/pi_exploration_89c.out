  p=19: g =    0.0000 +    4.3589i, |g|=4.3589, √p=4.3589, g/(i√p)=1.0000-0.0000j
  p=23: g =    0.0000 +    4.7958i, |g|=4.7958, √p=4.7958, g/(i√p)=1.0000-0.0000j
  p=43: g =    0.0000 +    6.5574i, |g|=6.5574, √p=6.5574, g/(i√p)=1.0000-0.0000j
