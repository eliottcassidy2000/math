  3     0    1       1         1      0           1     ✓
  3     1    0       1         1      0           1     ✓
  3     1    1       1         1      0           1     ✓
  3     2    0       3         1      1           3     ✓
  3     2    1       3         1      1           3     ✓
  3     3    0       1         1      0           1     ✓
  3     3    1       1         1      0           1     ✓
