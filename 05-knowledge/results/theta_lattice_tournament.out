  sigma_3(20) =     9198
  sigma_3(21) =     9632
  sigma_3(22) =    11988
  sigma_3(23) =    12168
  sigma_3(24) =    16380
  sigma_3(25) =    15751
  sigma_3(26) =    19782
  sigma_3(27) =    20440
