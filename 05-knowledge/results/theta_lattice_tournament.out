  sigma_3( 7) =      344
  sigma_3( 8) =      585
  sigma_3( 9) =      757
  sigma_3(10) =     1134
  sigma_3(11) =     1332
  sigma_3(12) =     2044
  sigma_3(13) =     2198
  sigma_3(14) =     3096
  sigma_3(15) =     3528
