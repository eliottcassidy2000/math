    dim(Omega_2) = 3
    Omega_2 basis vectors (in A_2 coords):
      basis 0: [((3, 2, 1), 1.0)]
      basis 1: [((2, 1, 0), 0.7071067811865475), ((3, 2, 0), 0.5000000000000001), ((3, 1, 0), -0.4999999999999999)]
      basis 2: [((2, 1, 0), 0.7071067811865475), ((3, 2, 0), -0.4999999999999999), ((3, 1, 0), 0.5000000000000001)]
