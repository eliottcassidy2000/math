    α=0.5236: det(I + αK) = 8.743775
    α=0.1111: det(I + αK) = 2.128385
  p=11: det(I + CD_kernel) = 645.486350, F_p = 144
    α=0.2000: det(I + αK) = 20.181139
    α=0.3142: det(I + αK) = 46.248950
    α=0.0400: det(I + αK) = 2.793133
