  m=6: det(M) = 377, B_m(1) = 377, F_{2m+1} = 233, det/B = 1.000000
  m=7: det(M) = 987, B_m(1) = 987, F_{2m+1} = 610, det/B = 1.000000
  m=8: det(M) = 2584, B_m(1) = 2584, F_{2m+1} = 1597, det/B = 1.000000
