Fibonacci matrix mod 4: powers
  M = [[1,1],[1,0]]
  M^ 1 mod 4 = [[1,1],[1,0]]
  M^ 2 mod 4 = [[2,1],[1,1]]
  M^ 3 mod 4 = [[3,2],[2,1]]
  M^ 4 mod 4 = [[1,3],[3,2]]
  M^ 5 mod 4 = [[0,1],[1,3]]
  M^ 6 mod 4 = [[1,0],[0,1]] = IDENTITY (order = 6)
  M^ 7 mod 4 = [[1,1],[1,0]]
  M^ 8 mod 4 = [[2,1],[1,1]]
  M^ 9 mod 4 = [[3,2],[2,1]]
  M^10 mod 4 = [[1,3],[3,2]]
  M^11 mod 4 = [[0,1],[1,3]]
  M^12 mod 4 = [[1,0],[0,1]] = IDENTITY (order = 12)

======================================================================
PART 2: TRANSFER MATRIX FOR I(P_k, x)
======================================================================

Transfer matrix T_x = [[1,x],[1,0]]:

  x=1: T = [[1,1],[1,0]]
    Eigenvalues: [ 1.61803399 -0.61803399]
    det = -1.0000, trace = 1.0000
    Char poly: λ² - λ - 1 = 0
    Roots: (1 ± √(1+4x))/2 = (1 ± √5)/2
    = φ ≈ 1.618034 and -1/φ ≈ -0.618034

  x=2: T = [[1,2],[1,0]]
    Eigenvalues: [ 2. -1.]
    det = -2.0000, trace = 1.0000
    Char poly: λ² - λ - 2 = 0
    Roots: (1 ± √(1+4x))/2 = (1 ± √9)/2
    = 2 and -1 (both integers! unique to x=2)

  x=3: T = [[1,3],[1,0]]
    Eigenvalues: [ 2.30277564 -1.30277564]
    det = -3.0000, trace = 1.0000
    Char poly: λ² - λ - 3 = 0
    Roots: (1 ± √(1+4x))/2 = (1 ± √13)/2

  x=-1: T = [[1,-1],[1,0]]
    Eigenvalues: [0.5+0.8660254j 0.5-0.8660254j]
    det = 1.0000, trace = 1.0000
    Char poly: λ² - λ - -1 = 0
    Roots: (1 ± √(1+4x))/2 = (1 ± √-3)/2

