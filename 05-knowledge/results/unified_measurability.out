  p=  7: F_p = 13.0000, nearest Fib = 13, ratio = 1.000000
  p= 11: F_p = 89.0000, nearest Fib = 89, ratio = 1.000000
  p= 19: F_p = 4181.0000, nearest Fib = 4181, ratio = 1.000000
  p= 23: F_p = 28657.0000, nearest Fib = 28657, ratio = 1.000000
