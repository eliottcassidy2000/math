  p = 7: Interval tournament
    Every arc has displacement in {1,...,3}
    HP count = # permutations with all steps in {1,...,3} mod p
    H = 175
    H(Paley) = 189
    Paley connection set: [1, 2, 4]
    Step sizes: [1, 2, 4]
    Paley gaps between consecutive steps: [1, 2]
    Interval has NO gaps (steps 1,2,...,3)

  p = 11: Interval tournament
    Every arc has displacement in {1,...,5}
    HP count = # permutations with all steps in {1,...,5} mod p
