Omega = [1, 5, 20, 70, 205, 460, 700, 690, 450, 180, 30]
m = 5, p = 11

k=0 EIGENSPACE:
  R^{(0)} = [0, 0, 5, 15, 55, 150, 305, 390, 300, 150, 30, 0]
  β^{(0)} = [1, 0, 0, 0, 0,  5,   5,   0,   0,   0,  0]
