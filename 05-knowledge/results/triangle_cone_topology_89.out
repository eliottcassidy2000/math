  Verify: c(n) = c(n-2) + c(n-3):
    c(3) = 1, c(1)+c(0) = 1, match = True
    c(4) = 1, c(2)+c(1) = 1, match = True
    c(5) = 2, c(3)+c(2) = 2, match = True
    c(6) = 2, c(4)+c(3) = 2, match = True
