  T#1: F=[1, 0, 0, 0, 0], w*=[1, -4, 6, -4, 1], H=1, nonneg=False
  T#2: F=[0, 1, 0, 0, 0], w*=[0, 1, -3, 3, -1], H=1, nonneg=False
