  T#5: F=[1, 4, 0, 0], w*=[1, 1, -5, 3], H=5, nonneg=False

  w* nonneg: 2/64
  w*_0 = F_0, w*_1 = H - n*F_0
  w*_0: min=0, max=1
  w*_1: min=-3, max=5
  w*_2: min=-6, max=4
  w*_3: min=-3, max=3

