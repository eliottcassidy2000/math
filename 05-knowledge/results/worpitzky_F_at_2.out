======================================================================
W^*(T,x) = REVERSED WORPITZKY POLYNOMIAL (h*-analog)
======================================================================
W^*(x) = sum_k w_{n-1-k} x^k
GF: sum_m F(T,m) x^m = W^*(T,x) / (1-x)^n


n=3:
  T#1: F=[1, 0, 0], w*=[1, -2, 1], H=1, nonneg=False
  T#2: F=[0, 1, 0], w*=[0, 1, -1], H=1, nonneg=False
  T#3: F=[1, 2, 0], w*=[1, 0, -1], H=3, nonneg=False
  T#4: F=[0, 1, 0], w*=[0, 1, -1], H=1, nonneg=False
  T#5: F=[0, 1, 0], w*=[0, 1, -1], H=1, nonneg=False

  w* nonneg: 1/8
  w*_0 = F_0, w*_1 = H - n*F_0
  w*_0: min=0, max=1
  w*_1: min=-2, max=3
  w*_2: min=-1, max=1

n=4:
  T#1: F=[1, 0, 0, 0], w*=[1, -3, 3, -1], H=1, nonneg=False
