  20        627      1      0      2      4  = 3*11*19
  21        792      0      0      2      1  = C(12,5) = C(h(E6),5)
  22       1002      0      0      2      1  = 2*3*167
  23       1255      1      1      0      2  = 5*251
  24       1575      1      0      0      0  
  25       1958      0      2      3      5  
  26       2436      0      0      1      0  
  27       3010      0      1      0      0  
