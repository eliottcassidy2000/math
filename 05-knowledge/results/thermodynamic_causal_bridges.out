    Score (np.int64(0), np.int64(2), np.int64(2), np.int64(3), np.int64(3)): Var=1.20, <H>=5.0, S=2.32 bits, Robustness=59.43%
    Score (np.int64(1), np.int64(1), np.int64(1), np.int64(3), np.int64(4)): Var=1.60, <H>=3.0, S=1.58 bits, Robustness=40.57%
    Score (np.int64(1), np.int64(1), np.int64(2), np.int64(2), np.int64(4)): Var=1.20, <H>=5.0, S=2.32 bits, Robustness=59.43%
    Score (np.int64(1), np.int64(1), np.int64(2), np.int64(3), np.int64(3)): Var=0.80, <H>=9.0, S=3.17 bits, Robustness=81.14%
    Score (np.int64(1), np.int64(2), np.int64(2), np.int64(2), np.int64(3)): Var=0.40, <H>=12.4, S=3.64 bits, Robustness=93.06%
