======================================================================
ANALYSIS 1: Z_v AS DETERMINISTIC FUNCTION OF SCORE
======================================================================

n=3: (n-1)/2 = 1.0
  Score | Z_v values | -2(s-m)^2+2 | match?
  ------+------------+-------------+-------
      0 |       [-1] |        0.00 | NO
      1 |        [1] |        2.00 | NO
      2 |       [-1] |        0.00 | NO
  Z_v deterministic by score? True
  Z(s) = -2.0000 * s^2 + 4.0000 * s + -1.0000
       = -2.0000 * (s - 1.0000)^2 + 1.0000
  Vertex at s = 1.0000 = (n-1)/2 = 1.0? YES

n=4: (n-1)/2 = 1.5
  Score | Z_v values | -2(s-m)^2+2 | match?
  ------+------------+-------------+-------
      0 |       [-3] |       -2.50 | NO
      1 |        [1] |        1.50 | NO
      2 |        [1] |        1.50 | NO
      3 |       [-3] |       -2.50 | NO
  Z_v deterministic by score? True
  Z(s) = -2.0000 * s^2 + 6.0000 * s + -3.0000
       = -2.0000 * (s - 1.5000)^2 + 1.5000
  Vertex at s = 1.5000 = (n-1)/2 = 1.5? YES

n=5: (n-1)/2 = 2.0
  Score | Z_v values | -2(s-m)^2+2 | match?
  ------+------------+-------------+-------
      0 |       [-6] |       -6.00 | YES
      1 |        [0] |        0.00 | YES
      2 |        [2] |        2.00 | YES
      3 |        [0] |        0.00 | YES
      4 |       [-6] |       -6.00 | YES
  Z_v deterministic by score? True
  Z(s) = -2.0000 * s^2 + 8.0000 * s + -6.0000
       = -2.0000 * (s - 2.0000)^2 + 2.0000
  Vertex at s = 2.0000 = (n-1)/2 = 2.0? YES

n=6: (n-1)/2 = 2.5
  Score | Z_v values | -2(s-m)^2+2 | match?
  ------+------------+-------------+-------
      0 |      [-10] |      -10.50 | NO
      1 |       [-2] |       -2.50 | NO
      2 |        [2] |        1.50 | NO
      3 |        [2] |        1.50 | NO
      4 |       [-2] |       -2.50 | NO
      5 |      [-10] |      -10.50 | NO
  Z_v deterministic by score? True
  Z(s) = -2.0000 * s^2 + 10.0000 * s + -10.0000
       = -2.0000 * (s - 2.5000)^2 + 2.5000
  Vertex at s = 2.5000 = (n-1)/2 = 2.5? YES

n=7: (too large, sampling)

n=7: (n-1)/2 = 3.0
  Score | Z_v values | -2(s-m)^2+2 | match?
  ------+------------+-------------+-------
      0 |      [-15] |      -16.00 | NO
      1 |       [-5] |       -6.00 | NO
      2 |        [1] |        0.00 | NO
      3 |        [3] |        2.00 | NO
      4 |        [1] |        0.00 | NO
      5 |       [-5] |       -6.00 | NO
      6 |      [-15] |      -16.00 | NO
  Z_v deterministic by score? True
  Z(s) = -2.0000 * s^2 + 12.0000 * s + -15.0000
       = -2.0000 * (s - 3.0000)^2 + 3.0000
  Vertex at s = 3.0000 = (n-1)/2 = 3.0? YES

