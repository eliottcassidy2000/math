      Before: 0 use 4->6, 2 use 6->4
      After:  0 use 4->6, 0 use 6->4

  Pair (5,6), arc 5->6 (reversed):
    Net change: 3
    ext=[0, 2, 3]: 1->2 (d=1)
      Before: 0 use 5->6, 0 use 6->5
      After:  0 use 5->6, 1 use 6->5
    ext=[0, 3, 7]: 1->3 (d=2)
      Before: 0 use 5->6, 0 use 6->5
      After:  0 use 5->6, 2 use 6->5

