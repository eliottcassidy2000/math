                     mod 8: [1, 3], mod 10: [1], mod 11: [0, 1]
      x=11           mod 2: [0, 1], mod 3: [0, 1], mod 7: [1, 5]
                     mod 8: [1, 4], mod 10: [1, 2], mod 11: [1]

