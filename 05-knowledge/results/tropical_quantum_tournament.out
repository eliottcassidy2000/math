PART 4: KEMENY DISTANCE — TOURNAMENT AS VOTING SYSTEM
  Kemeny distance = min # arc flips to make transitive
  = min # pairwise comparisons to change for a total order
  Connection to H: more transitive (low Kemeny) = low H?
======================================================================

--- n = 4 ---
  H -> Kemeny distance:
    H=  1: Kemeny in [0]
    H=  3: Kemeny in [1]
    H=  5: Kemeny in [1]

  Correlation(H, Kemeny) = 0.894427

--- n = 5 ---
  H -> Kemeny distance:
    H=  1: Kemeny in [0]
    H=  3: Kemeny in [1]
    H=  5: Kemeny in [1]
    H=  9: Kemeny in [1, 2]
    H= 11: Kemeny in [2]
    H= 13: Kemeny in [2]
    H= 15: Kemeny in [2, 3]

  Correlation(H, Kemeny) = 0.884438

