  --- D^{2n} DECOMPOSITION ---
  h_hat[{a,b}] = sum_n D^{2n}_ab / 2^m
  For q-resonant pair: D^{2n}_ab nonzero only at n >= (q+1)/2
  Sign of D^{2n} at onset: chi(q) * chi(ab)

    q=3: onset at D^4, sign(D^4) = chi(q)*chi(ab) = (+1)*(+1) = +1
    h_hat =     544.5000, sign(h_hat) = +1, chi(ab) = +1
    => D^4 has CORRECT sign for product law

    q=5: onset at D^6, sign(D^6) = chi(q)*chi(ab) = (+1)*(-1) = -1
    h_hat =     -16.5000, sign(h_hat) = -1, chi(ab) = -1
    => D^6 has CORRECT sign for product law



============================================================
PART 4: EXPLICIT h_hat FORMULA AT p=7
============================================================

  All H values (sigma_0=+1 half):
    sigma=[-1, -1, -1], S=[4, 5, 6], H=175
    sigma=[1, -1, -1], S=[1, 4, 5], H=175
    sigma=[-1, 1, -1], S=[2, 4, 6], H=175
    sigma=[1, 1, -1], S=[1, 2, 4], H=189
    sigma=[-1, -1, 1], S=[3, 5, 6], H=189
    sigma=[1, -1, 1], S=[1, 3, 5], H=175
    sigma=[-1, 1, 1], S=[2, 3, 6], H=175
    sigma=[1, 1, 1], S=[1, 2, 3], H=175

  h_hat[{0,1}] = (1/2^m) * sum H(sigma) * sigma_0 * sigma_1
  = (2/2^m) * sum_(sigma_0=+1) H(sigma) * sigma_0 * sigma_1
  = (2/8) * sum_(sigma_0=+1) H(sigma) * sigma_1
    sigma=[-1, -1, -1], H=175, s0*s1=+1, contrib=+175
    sigma=[1, -1, -1], H=175, s0*s1=-1, contrib=-175
    sigma=[-1, 1, -1], H=175, s0*s1=-1, contrib=-175
    sigma=[1, 1, -1], H=189, s0*s1=+1, contrib=+189
    sigma=[-1, -1, 1], H=189, s0*s1=+1, contrib=+189
    sigma=[1, -1, 1], H=175, s0*s1=-1, contrib=-175
    sigma=[-1, 1, 1], H=175, s0*s1=-1, contrib=-175
    sigma=[1, 1, 1], H=175, s0*s1=+1, contrib=+175
  Total = 28, h_hat = 2*28/8 = 7.0000

  H(Paley) = 189, H(non-Paley) = 175
  Difference = 14 = 2*p = 2*7
  h_hat = 2*(189-175*3)/(2^3) ... no, need full Walsh
  |h_hat_2| = p/2 = 3.5 for ALL degree-2 at p=7
