  p=37: Q_1/Q_2 = 8.9568, Q_1 = 138.7921, Q_2 = 15.495682
  p=41: Q_1/Q_2 = 8.9648, Q_1 = 170.4043, Q_2 = 19.008099
  p=43: Q_1/Q_2 = 8.9680, Q_1 = 187.4262, Q_2 = 20.899408
  p=47: Q_1/Q_2 = 8.9732, Q_1 = 223.9018, Q_2 = 24.952223
