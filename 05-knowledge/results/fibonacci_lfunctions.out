  n=  6: L=        18, F=         8, L²-5F² =      4 = 4·(-1)^6 = 4
  n=  7: L=        29, F=        13, L²-5F² =     -4 = 4·(-1)^7 = -4
  n=  8: L=        47, F=        21, L²-5F² =      4 = 4·(-1)^8 = 4
  n=  9: L=        76, F=        34, L²-5F² =     -4 = 4·(-1)^9 = -4
  n= 10: L=       123, F=        55, L²-5F² =      4 = 4·(-1)^10 = 4
  n= 11: L=       199, F=        89, L²-5F² =     -4 = 4·(-1)^11 = -4
