DECOMPOSITION OF Om_2
======================================================================
bits=0, scores=(0, 1, 2, 3, 4), c3=0
  |A2|=10, TT=10, Junk=0
  |A2| = sum d_b^out * d_b^in = sum d_b * (n-1-d_b)
  n_bp=0
  Om2 = |A2| - n_bp = 10 - 0 = 10
bits=341, scores=(2, 2, 2, 2, 2), c3=5
  |A2|=20, TT=5, Junk=15
  |A2| = sum d_b^out * d_b^in = sum d_b * (n-1-d_b)
  n_bp=10
  Om2 = |A2| - n_bp = 20 - 10 = 10
bits=10, scores=(1, 1, 2, 3, 3), c3=3
  |A2|=16, TT=7, Junk=9
  |A2| = sum d_b^out * d_b^in = sum d_b * (n-1-d_b)
  n_bp=7
  Om2 = |A2| - n_bp = 16 - 7 = 9

