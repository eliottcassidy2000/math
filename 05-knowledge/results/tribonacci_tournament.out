  k=4 (9 vertices): I(x) coeffs = [1, 9, 24, 20, 4], I(2) = 339
  k=5 (11 vertices): I(x) coeffs = [1, 11, 40, 56, 28, 4], I(2) = 1207
  k=6 (13 vertices): I(x) coeffs = [1, 13, 60, 120, 104, 36, 4], I(2) = 4299
  k=7 (15 vertices): I(x) coeffs = [1, 15, 84, 220, 280, 168, 44, 4], I(2) = 15311

