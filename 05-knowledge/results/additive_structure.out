    k<=3: cum=            -0.0 (-, k%4=3)
    k<=5: cum=           440.0 (+, k%4=1)
    k<=7: cum=        -11792.0 (-, k%4=3)
    k<=9: cum=        265232.0 (+, k%4=1)
    k<=11: cum=      -5593104.0 (-, k%4=3)
  p=19: Cumulative Delta_H (partial sums up to k):
    k<=3: cum=             0.0 (+, k%4=3)
    k<=5: cum=          4560.0 (+, k%4=1)
    k<=7: cum=       -362976.0 (-, k%4=3)
    k<=9: cum=      25935456.0 (+, k%4=1)
    k<=11: cum=   -1814727392.0 (-, k%4=3)
    k<=13: cum=  125467759776.0 (+, k%4=1)
